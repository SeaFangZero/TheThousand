# Copy to .env for local dev (netlify dev reads it). Never commit the real .env.
# In production, set these in Netlify: Site settings -> Environment variables.

# YouTube Data API v3 key. Google Cloud Console -> enable "YouTube Data API v3"
# -> Credentials -> Create API key.
YOUTUBE_API_KEY=

# The secret word your group shares. Anyone with it can add one entry.
JOIN_CODE=
